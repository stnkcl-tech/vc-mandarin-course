# Google Gemini API Key
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Moonshot AI (Kimi) API Key
# Get yours at: https://platform.moonshot.ai/
MOONSHOT_API_KEY=your_moonshot_api_key_here

# OpenAI API Key
# OPENAI_API_KEY=your_openai_api_key_here

# AI Provider: "gemini", "moonshot", or "openai"
AI_PROVIDER=gemini

# Model name
# Gemini: gemini-2.5-pro, gemini-2.0-flash
# Moonshot: kimi-k2.6
# OpenAI: gpt-4o, gpt-4o-mini
AI_MODEL=gemini-2.5-pro

# Context folder path (absolute or relative to project root)
CONTEXT_PATH=../_context

# Server port (optional, default 8000)
PORT=8000
